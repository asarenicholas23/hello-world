rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /facilities/{fileNumber}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
    match /staff-photos/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
