rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // Staff doc is keyed by Firebase Auth UID — O(1) lookup, no query needed.
    function staffRole() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role;
    }

    function isDirector()         { return isAuthed() && staffRole() == 'director'; }
    function isAdmin()            { return isAuthed() && staffRole() == 'admin'; }
    function isSeniorOfficer()    { return isAuthed() && staffRole() == 'senior_officer'; }
    function isOfficer()          { return isAuthed() && staffRole() == 'officer'; }
    function isAssistantOfficer() { return isAuthed() && staffRole() == 'assistant_officer'; }
    function isJuniorOfficer()    { return isAuthed() && staffRole() == 'junior_officer'; }
    function isFinance()          { return isAuthed() && staffRole() == 'finance'; }

    // Any role that does field work
    function isFieldRole() {
      return isSeniorOfficer() || isOfficer() || isAssistantOfficer() || isJuniorOfficer();
    }

    function canEditAllEntries() {
      return isDirector() || isAdmin() || isSeniorOfficer() || isOfficer();
    }

    // ── Staff ──────────────────────────────────────────────────
    // Any authenticated user can read staff docs (needed for name lookups).
    // Admin can do anything. A user can update their own doc provided they
    // don't change their role, staff_id, or role_level.
    match /staff/{uid} {
      allow read:             if isAuthed();
      allow create, delete:   if isAdmin();
      allow update:           if isAdmin()
                                || (isAuthed() && request.auth.uid == uid
                                    && request.resource.data.role       == resource.data.role
                                    && request.resource.data.staff_id   == resource.data.staff_id
                                    && request.resource.data.role_level == resource.data.role_level);
    }

    // ── Counters ───────────────────────────────────────────────
    // Authenticated users need read+write for the file-number transaction
    // (Phase 2). Write access tightened to admins+officers in Phase 2.
    match /counters/{prefix} {
      allow read, write: if isAuthed();
    }

    // ── Facilities ─────────────────────────────────────────────
    match /facilities/{fileNumber} {
      allow read:          if isAuthed();
      allow create:        if isAdmin() || isFieldRole();
      allow update:        if canEditAllEntries() || isFinance() || isFieldRole();
      allow delete:        if canEditAllEntries();

      // Permits — admin/director full access; assigned field officer can create
      match /permits/{id} {
        allow read:           if isAuthed();
        allow create:         if isAdmin() || isDirector()
                                || (isFieldRole() && get(/databases/$(database)/documents/facilities/$(fileNumber)).data.primary_officer == request.auth.uid);
        allow update:         if canEditAllEntries();
        allow delete:         if canEditAllEntries();
      }

      // Assignment history on the facility itself (append-only)
      match /assignment_history/{hid} {
        allow read:           if isAuthed();
        allow create:         if canEditAllEntries() || isFieldRole();
        allow update, delete: if false;
      }

      // Finance — admin, director, or finance role
      match /finance/{id} {
        allow read:        if isAuthed();
        allow create:      if canEditAllEntries() || isFinance();
        allow update:      if canEditAllEntries() || isFinance();
        allow delete:      if canEditAllEntries() || isFinance();
      }

      // Field sub-records — admin or any field role
      match /screenings/{id} {
        allow read:        if isAuthed();
        allow write:       if canEditAllEntries() || isFieldRole();
      }

      match /site_verifications/{id} {
        allow read:        if isAuthed();
        allow write:       if canEditAllEntries() || isFieldRole();
      }

      match /monitoring/{id} {
        allow read:        if isAuthed();
        allow write:       if canEditAllEntries() || isFieldRole();
      }

      match /enforcement/{id} {
        allow read:        if isAuthed();
        allow write:       if canEditAllEntries() || isFieldRole();
      }
    }

    // ── Field Reports (top-level collection for unregistered facilities) ──
    match /field_reports/{id} {
      allow read:   if isAuthed();
      allow create: if canEditAllEntries() || isFieldRole();
      allow update: if canEditAllEntries() || isFieldRole() || isFinance();
      allow delete: if canEditAllEntries();

      match /assignment_history/{hid} {
        allow read:           if isAuthed();
        allow create:         if canEditAllEntries() || isFieldRole();
        allow update, delete: if false;
      }
    }

    // ── Complaints ─────────────────────────────────────────────────
    match /complaints/{id} {
      allow read:          if isAuthed();
      allow create:        if canEditAllEntries() || isFieldRole();
      allow update:        if canEditAllEntries() || (isFieldRole() && resource.data.created_by == request.auth.uid);
      allow delete:        if isAdmin();
    }

    // ── Environmental Education ────────────────────────────────────
    match /environmental_education/{id} {
      allow read:          if isAuthed();
      allow create:        if canEditAllEntries() || isFieldRole();
      allow update:        if canEditAllEntries() || (isFieldRole() && resource.data.created_by == request.auth.uid);
      allow delete:        if isAdmin();
    }

    // ── SMS log (written only by Cloud Functions via Admin SDK) ───
    match /sms_log/{id} {
      allow read:  if isAdmin() || isDirector();
      allow write: if false;
    }
    match /sms_dedup/{id} {
      allow read, write: if false;
    }

    // ── collectionGroup reads (cross-facility views & dashboard) ──
    // These wildcard rules allow collectionGroup() queries used on the
    // dashboard and cross-facility listing pages. Write access is still
    // governed by the specific subcollection rules above.
    match /{path=**}/permits/{id}            { allow read: if isAuthed(); }
    match /{path=**}/assignment_history/{id}  { allow read: if isAuthed(); }
    match /{path=**}/finance/{id}            { allow read: if isAuthed(); }
    match /{path=**}/screenings/{id}         { allow read: if isAuthed(); }
    match /{path=**}/site_verifications/{id} { allow read: if isAuthed(); }
    match /{path=**}/monitoring/{id}         { allow read: if isAuthed(); }
    match /{path=**}/enforcement/{id}        { allow read: if isAuthed(); }
  }
}
